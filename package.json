{
  "name": "mvpproject",
  "version": "1.0.0",
  "description": "This project is an IP Access Control REST API that allows users, services, and approved IP records to be managed through a relational database. The goal is to provide a backend foundation for a system that verifies whether a users IP address is allowed to access a specific internal service.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "db:setup": "node database/setup.js",
    "db:seed": "node database/seed.js",
    "test": "jest"
  },
